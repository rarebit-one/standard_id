# StandardId Environment Variables
# Copy this file to .env and fill in your values.

# JWT signing key (PEM format, newlines replaced with \n)
# Generate ES256: openssl ecparam -name prime256v1 -genkey -noout -out signing_key.pem
# Generate RS256: openssl genrsa -out signing_key.pem 2048
# Convert to env: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' signing_key.pem
# JWT_SIGNING_KEY=

# Google OAuth (requires standard_id-google gem)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Apple Sign In (requires standard_id-apple gem)
# APPLE_CLIENT_ID=
# APPLE_MOBILE_CLIENT_ID=
# APPLE_PRIVATE_KEY=
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
