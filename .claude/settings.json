{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git merge-base:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git pull:*)",
      "Bash(git tag:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(bundle:*)",
      "Bash(gem build:*)",
      "Bash(gem info:*)",
      "Bash(rm *.gem)",
      "Skill(publish-gem)",
      "Bash(git worktree:*)",
      "Bash(git stash:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-worktree.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
